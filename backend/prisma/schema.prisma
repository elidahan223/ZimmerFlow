generator client {
  provider      = "prisma-client-js"
  // "native" covers local dev (Windows / debian-based CI runner).
  // "rhel-openssl-3.0.x" is required for Amazon Linux 2023 on EB.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  cognitoSub   String?  @unique @map("cognito_sub")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  email        String?  @unique
  phone        String?
  idNumber     String?  @map("id_number")
  address      String?
  role         Role     @default(OWNER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  auditLogs      AuditLog[]
  createdBookings Booking[] @relation("CreatedByUser")

  @@map("users")
}

model Customer {
  id        String   @id @default(uuid())
  fullName  String   @map("full_name")
  phone     String
  email     String?
  idNumber  String?  @map("id_number")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  bookings      Booking[]
  notifications Notification[]

  @@map("customers")
}

model Compound {
  id              String      @id @default(uuid())
  name            String
  color           String          @default("#3b82f6")
  description     String?
  tagline         String?
  capacity        Int
  status          CompoundStatus @default(ACTIVE)
  weekdayPrice    Decimal     @map("weekday_price")
  weekendPrice    Decimal     @map("weekend_price")
  holidayPrice    Decimal?    @map("holiday_price")
  yardDescription String?     @map("yard_description")
  videoUrl        String?     @map("video_url")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  rooms              Room[]
  bookings           Booking[]
  availabilityBlocks AvailabilityBlock[]
  images             CompoundImage[]

  @@map("compounds")
}

model Room {
  id          String   @id @default(uuid())
  compoundId  String   @map("compound_id")
  name        String
  description String?
  capacity    Int?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  compound     Compound      @relation(fields: [compoundId], references: [id], onDelete: Cascade)
  images       RoomImage[]
  bookingRooms BookingRoom[]

  @@map("rooms")
}

model CompoundImage {
  id         String   @id @default(uuid())
  compoundId String   @map("compound_id")
  url        String
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  compound Compound @relation(fields: [compoundId], references: [id], onDelete: Cascade)

  @@map("compound_images")
}

model RoomImage {
  id        String   @id @default(uuid())
  roomId    String   @map("room_id")
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("room_images")
}

model Booking {
  id              String        @id @default(uuid())
  customerId      String        @map("customer_id")
  compoundId      String        @map("compound_id")
  createdByUserId String        @map("created_by_user_id")
  checkIn         DateTime      @map("check_in")
  checkOut        DateTime      @map("check_out")
  guestsCount     Int           @map("guests_count")
  adults          Int           @default(2)
  children        Int           @default(0)
  status          BookingStatus @default(PENDING_PAYMENT)
  customerNotes   String?       @map("customer_notes")
  adminNotes      String?       @map("admin_notes")
  // Bookings created from one request (potentially across multiple compounds)
  // share a bookingGroupId so the deposit Payment can cover the whole group.
  bookingGroupId  String?       @map("booking_group_id")
  totalPrice      Decimal?      @map("total_price")
  depositAmount   Decimal?      @map("deposit_amount")
  depositPaidAt   DateTime?     @map("deposit_paid_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  completedAt     DateTime?     @map("completed_at")
  cancelledAt     DateTime?     @map("cancelled_at")

  customer      Customer       @relation(fields: [customerId], references: [id])
  compound      Compound       @relation(fields: [compoundId], references: [id])
  createdByUser User           @relation("CreatedByUser", fields: [createdByUserId], references: [id])
  bookingRooms  BookingRoom[]
  contracts     Contract[]
  notifications Notification[]
  payments      Payment[]

  @@index([bookingGroupId])
  @@map("bookings")
}

model BookingRoom {
  id        String   @id @default(uuid())
  bookingId String   @map("booking_id")
  roomId    String   @map("room_id")
  createdAt DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  room    Room    @relation(fields: [roomId], references: [id])

  @@unique([bookingId, roomId])
  @@map("booking_rooms")
}

model AvailabilityBlock {
  id         String   @id @default(uuid())
  compoundId String   @map("compound_id")
  startDate  DateTime @map("start_date")
  endDate    DateTime @map("end_date")
  blockType  String   @map("block_type")
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  compound Compound @relation(fields: [compoundId], references: [id])

  @@map("availability_blocks")
}

model Contract {
  id              String         @id @default(uuid())
  bookingId       String         @map("booking_id")
  contractNumber  String         @map("contract_number")
  templateVersion String         @map("template_version")
  status          ContractStatus @default(DRAFT)
  fileUrl         String?        @map("file_url")
  signedFileUrl   String?        @map("signed_file_url")
  generatedAt     DateTime       @default(now()) @map("generated_at")
  signedAt        DateTime?      @map("signed_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  booking         Booking          @relation(fields: [bookingId], references: [id])
  signatureEvents SignatureEvent[]

  @@map("contracts")
}

model SignatureEvent {
  id         String   @id @default(uuid())
  contractId String   @map("contract_id")
  eventType  String   @map("event_type")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  metadata   Json?
  eventTime  DateTime @default(now()) @map("event_time")

  contract Contract @relation(fields: [contractId], references: [id])

  @@map("signature_events")
}

model Notification {
  id             String   @id @default(uuid())
  bookingId      String   @map("booking_id")
  customerId     String   @map("customer_id")
  type           String
  channel        String
  status         String
  messageContent String?  @map("message_content")
  sentAt         DateTime? @map("sent_at")
  createdAt      DateTime @default(now()) @map("created_at")

  booking  Booking  @relation(fields: [bookingId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@map("notifications")
}

model Payment {
  id                    String        @id @default(uuid())
  bookingGroupId        String        @map("booking_group_id")
  // Convenience FK to one of the bookings in the group so Prisma can join,
  // but the source of truth for "which bookings does this payment cover" is
  // bookingGroupId. The handler updates every booking sharing that group.
  bookingId             String        @map("booking_id")
  amount                Decimal
  currency              String        @default("ILS")
  type                  PaymentType
  status                PaymentStatus @default(PENDING)
  // Cardcom Low Profile identifiers
  cardcomLowProfileId   String?       @map("cardcom_low_profile_id")
  cardcomTransactionId  String?       @map("cardcom_transaction_id")
  cardcomDealNumber     String?       @map("cardcom_deal_number")
  cardLast4             String?       @map("card_last4")
  // Raw responses we get from Cardcom (Create + GetLpResult + Webhook) so we
  // can debug a stuck payment without re-hitting their API.
  rawResponse           Json?         @map("raw_response")
  errorMessage          String?       @map("error_message")
  paidAt                DateTime?     @map("paid_at")
  failedAt              DateTime?     @map("failed_at")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingGroupId])
  @@index([cardcomLowProfileId])
  @@map("payments")
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String   @map("actor_user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  actor User @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
}

enum Role {
  ADMIN
  OWNER
  GUEST
}

enum CompoundStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum BookingStatus {
  PENDING_PAYMENT
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentType {
  DEPOSIT
  REMAINDER
  FULL
  REFUND
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  EXPIRED
}
