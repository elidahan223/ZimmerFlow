# ──────────────────────────────────────────────────────────────────────────
# ZimmerFlow backend env vars
# In production these are set in Elastic Beanstalk → Configuration →
# Updates, monitoring, and logging → Environment properties.
# ──────────────────────────────────────────────────────────────────────────

# Express / runtime
NODE_ENV=production
PORT=8080

# Frontend origin (used for CORS + payment-redirect targets)
FRONTEND_URL=https://example.cloudfront.net

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/zimmerflow?sslmode=require

# JWT
JWT_SECRET=replace-with-strong-random-string

# AWS / Cognito
AWS_REGION=eu-central-1
COGNITO_USER_POOL_ID=...
COGNITO_CLIENT_ID=...
COGNITO_CLIENT_SECRET=...
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# S3 (contracts + images live in eu-north-1)
S3_REGION=eu-north-1

# Anthropic (AI booking agent)
ANTHROPIC_API_KEY=...

# ──────────────────────────────────────────────────────────────────────────
# Cardcom — payment processing (Low Profile API v11)
# Get these from Cardcom admin panel → יישומונים → API.
# For the playground/test terminal Cardcom publishes:
#   CARDCOM_TERMINAL=1000  CARDCOM_API_NAME=barak9611
# Production uses your own terminal number + ApiName.
# ──────────────────────────────────────────────────────────────────────────
CARDCOM_TERMINAL=1000
CARDCOM_API_NAME=barak9611
CARDCOM_API_PASSWORD=
# Set to 'true' to have Cardcom issue a TaxInvoiceAndReceipt and email it
# to the customer after every successful charge. Leave unset / 'false'
# until the Cardcom account is provisioned for invoice issuance
# (סיפרור מסמכים + תעודה דיגיטלית), otherwise every booking will fail
# at the Document validation step.
CARDCOM_ISSUE_INVOICE=false
# Override only if Cardcom give you a non-default API host.
# CARDCOM_BASE_URL=https://secure.cardcom.solutions
